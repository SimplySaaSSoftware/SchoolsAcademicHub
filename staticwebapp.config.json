{
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] },
    { "route": "/superadmin*", "rewrite": "/superadmin.html" },
    { "route": "/reset-password*", "rewrite": "/reset-password.html" },
    { "route": "/:school/student*", "rewrite": "/student.html" },
    { "route": "/:school/teacher*", "rewrite": "/teacher.html" },
    { "route": "/:school/admin*",   "rewrite": "/admin.html" },
    { "route": "/:school*",         "rewrite": "/index.html" }
  ],
  "globalHeaders": {
    "Cache-Control": "no-cache, must-revalidate"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.css", "*.js", "*.png", "*.jpg", "*.ico"]
  }
}
