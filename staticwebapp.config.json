{
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] },
    { "route": "/superadmin",   "rewrite": "/superadmin.html" },
    { "route": "/superadmin/*", "rewrite": "/superadmin.html" },
    { "route": "/reset-password",   "rewrite": "/reset-password.html" },
    { "route": "/reset-password/*", "rewrite": "/reset-password.html" },
    { "route": "/*/student",   "rewrite": "/student.html" },
    { "route": "/*/student/*", "rewrite": "/student.html" },
    { "route": "/*/teacher",   "rewrite": "/teacher.html" },
    { "route": "/*/teacher/*", "rewrite": "/teacher.html" },
    { "route": "/*/admin",     "rewrite": "/admin.html" },
    { "route": "/*/admin/*",   "rewrite": "/admin.html" },
    { "route": "/*",           "rewrite": "/index.html" }
  ],
  "globalHeaders": {
    "Cache-Control": "no-cache, must-revalidate"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.css", "*.js", "*.png", "*.jpg", "*.ico", "*.webp", "*.svg"]
  }
}
